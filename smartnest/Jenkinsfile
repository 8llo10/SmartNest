pipeline {
    agent any

    options {
        disableConcurrentBuilds()
        timestamps()
    }

    parameters {
        booleanParam(name: 'RUN_DEPLOY', defaultValue: true, description: 'Run Deploy stage after packaging')
        booleanParam(name: 'SIMULATE_TEST_FAILURE', defaultValue: false, description: 'Demo failure handling by failing in the Test stage')
    }

    triggers {
        cron('H H * * *')
    }

    environment {
        APP_NAME = "SmartNest"
        IMAGE_NAME = "smartnest"
        CONTAINER_NAME = "smartnest-container"
        APP_PORT = "3000"
        PATH = "/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin"
    }

    stages {
        stage('Install') {
            steps {
                script {
                    def appDir = fileExists('package.json') ? '.' : 'smartnest'
                    dir(appDir) {
                        if (isUnix()) {
                            sh 'npm ci || npm install'
                        } else {
                            bat 'call npm ci || call npm install'
                        }
                    }
                }
            }
        }

        stage('Build') {
            steps {
                script {
                    def appDir = fileExists('package.json') ? '.' : 'smartnest'
                    dir(appDir) {
                        if (isUnix()) {
                            sh 'npm run build'
                        } else {
                            bat 'call npm run build'
                        }
                    }
                }
            }
        }

        stage('Test') {
            steps {
                script {
                    def appDir = fileExists('package.json') ? '.' : 'smartnest'
                    dir(appDir) {
                        if (params.SIMULATE_TEST_FAILURE) {
                            if (isUnix()) {
                                sh 'echo "Simulating test failure for failure-handling demo" && exit 1'
                            } else {
                                bat 'echo Simulating test failure for failure-handling demo && exit /b 1'
                            }
                        }

                        if (isUnix()) {
                            sh 'npm test'
                        } else {
                            bat 'call npm test'
                        }
                    }
                }
            }
        }

        stage('Package') {
            steps {
                script {
                    def appDir = fileExists('package.json') ? '.' : 'smartnest'
                    dir(appDir) {
                        if (isUnix()) {
                            sh "docker build -t ${IMAGE_NAME}:${BUILD_NUMBER} ."
                            sh "docker save -o ${IMAGE_NAME}-${BUILD_NUMBER}.tar ${IMAGE_NAME}:${BUILD_NUMBER}"
                        } else {
                            bat "docker build -t %IMAGE_NAME%:%BUILD_NUMBER% ."
                            bat "docker save -o %IMAGE_NAME%-%BUILD_NUMBER%.tar %IMAGE_NAME%:%BUILD_NUMBER%"
                        }
                    }
                }
            }
        }

        stage('Deploy') {
            when {
                expression { return params.RUN_DEPLOY }
            }
            steps {
                script {
                    def appDir = fileExists('package.json') ? '.' : 'smartnest'
                    dir(appDir) {
                        if (isUnix()) {
                            sh '''
                                if docker ps -a --format '{{.Names}}' | grep -Eq "^${CONTAINER_NAME}$"; then
                                    docker rm -f "${CONTAINER_NAME}"
                                fi
                                docker run -d --name "${CONTAINER_NAME}" -p "${APP_PORT}:80" "${IMAGE_NAME}:${BUILD_NUMBER}"
                            '''
                        } else {
                            bat '''
                                for /f "tokens=*" %%i in ('docker ps -a --format "{{.Names}}" ^| findstr /r /c:"^%CONTAINER_NAME%$"') do docker rm -f %CONTAINER_NAME%
                                docker run -d --name %CONTAINER_NAME% -p %APP_PORT%:80 %IMAGE_NAME%:%BUILD_NUMBER%
                            '''
                        }
                    }
                }
            }
        }
    }

    post {
        always {
            archiveArtifacts artifacts: 'dist/**, *.tar, smartnest/dist/**, smartnest/*.tar', allowEmptyArchive: true
        }
        success {
            echo 'SmartNest pipeline completed successfully.'
        }
        failure {
            echo 'SmartNest pipeline failed. Fix the failed stage, then re-run the pipeline.'
        }
    }
}
